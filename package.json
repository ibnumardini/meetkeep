{
  "name": "meetkeep",
  "version": "1.2.3",
  "description": "A Chrome extension that automatically injects a meeting timer into Google Meet.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "bun scripts/zip.js",
    "zip:firefox": "bun scripts/zip.js -b firefox",
    "build:docs": "bun scripts/build-docs.js",
    "watch:docs": "bun scripts/watch-docs.js"
  },
  "keywords": [
    "chrome-extension",
    "google-meet",
    "meeting-timer"
  ],
  "author": "Muhammad Fatkurozi <hi@mardini.dev>",
  "license": "Apache-2.0",
  "private": true,
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "chokidar": "^5.0.0",
    "clean-css": "^5.3.3",
    "terser": "^5.48.0",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
