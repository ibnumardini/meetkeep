{
  "manifest_version": 3,
  "name": "MeetKeep - Google Meet Timer",
  "version": "1.0.0",
  "description": "Automatically injects a meeting timer into Google Meet.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
